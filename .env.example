# Planymaps Environment Configuration
# Copy this file to .env.local and fill in your values
# All values here should match those configured in Appwrite dashboard

# ===========================================
# APPWRITE CONFIGURATION
# ===========================================

# Appwrite Endpoint
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://aprod.racoondevs.com/v1

# Appwrite Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=planymaps

# Appwrite API Key (server-side only, never expose to client)
APPWRITE_API_KEY=example

# ===========================================
# APPWRITE DATABASE & COLLECTIONS
# ===========================================

# Database ID (created in Appwrite > Databases)
APPWRITE_DATABASE_ID=planymaps_db

# Collection IDs (created in Appwrite > Databases > planymaps_db > Collections)
APPWRITE_COLLECTION_WORKSPACES=workspaces
APPWRITE_COLLECTION_WORKSPACE_MEMBERS=workspace_members
APPWRITE_COLLECTION_BOARDS=boards
APPWRITE_COLLECTION_BOARD_LAYERS=board_layers
APPWRITE_COLLECTION_BOARD_ITEMS=board_items
APPWRITE_COLLECTION_BOARD_ASSETS=board_assets

# ===========================================
# APPWRITE STORAGE BUCKETS
# ===========================================

# Storage Bucket IDs (created in Appwrite > Storage)
APPWRITE_BUCKET_AVATARS=avatars
APPWRITE_BUCKET_BOARD_ASSETS=board_assets
APPWRITE_BUCKET_BOARD_THUMBNAILS=board_thumbnails

# ===========================================
# MAP/GEOLOCATION CONFIGURATION (Future)
# ===========================================

# Map Provider API Key (e.g., Google Maps, Mapbox, etc.)
# NEXT_PUBLIC_MAP_PROVIDER_API_KEY=your_map_api_key

# Map Style URL (for custom map styles)
# NEXT_PUBLIC_MAP_STYLE_URL=https://api.mapbox.com/styles/v1/your-username/your-style

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application Name
NEXT_PUBLIC_APP_NAME=Planymaps

# Application URL (for OAuth redirects, password reset, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# SMTP/EMAIL CONFIGURATION (Future - for notifications)
# ===========================================

# SMTP Host
# SMTP_HOST=smtp.mailgun.org

# SMTP Port
# SMTP_PORT=587

# SMTP Username
# SMTP_USERNAME=your_smtp_username

# SMTP Password
# SMTP_PASSWORD=your_smtp_password

# SMTP From Email
# SMTP_FROM=notifications@yourdomain.com
